{
    "name": "UAV",
    "image": "arm-gcc:latest",
    "workspaceMount": "source=${localWorkspaceFolder}/app,target=/workspace,type=bind",
    "workspaceFolder": "/workspace",
    "runArgs": ["--privileged"],
    "postCreateCommand": [
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "twxs.cmake",
                "ms-vscode.cpptools-extension-pack",
                "marus25.cortex-debug"
            ]
        }
    }
}